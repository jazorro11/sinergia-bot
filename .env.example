# Copia este archivo a .env y completa los valores (nunca subas .env al repositorio).

# --- Requeridas (el arranque falla si faltan cuando config.py valida el entorno) ---

# Telegram — token de BotFather
TELEGRAM_BOT_TOKEN=

# OpenRouter — API key (el cliente OpenAI apunta a https://openrouter.ai/api/v1)
OPENROUTER_API_KEY=

# Google Sheets — JSON de la cuenta de servicio en una sola línea (string), para Railway/Render
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheets — ID del spreadsheet (hojas leads y conversaciones)
GOOGLE_SHEET_ID=

# Calendly — URL pública del evento (el bot la incluye al cerrar)
CALENDLY_URL=

# Modelos en OpenRouter (formato proveedor/modelo)
LLM_MODEL=openai/gpt-4o
LLM_EXTRACTION_MODEL=openai/gpt-4o-mini

# --- Opcionales (valores por defecto si no se definen) ---

# Cada cuántos mensajes del usuario se ejecuta la extracción (default: 1)
EXTRACTION_FREQUENCY=1

# Nivel de logging (default: INFO)
LOG_LEVEL=INFO

# Puerto del servidor — Railway/Render inyectan PORT; en local suele ser 8000
PORT=8000
