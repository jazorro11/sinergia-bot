# Copia este archivo a .env y completa los valores (nunca subas .env al repositorio).

# --- Requeridas (el arranque falla si faltan cuando config.py valida el entorno) ---

# Telegram — token de BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI — API key (el SDK openai usa por defecto https://api.openai.com/v1)
OPENAI_API_KEY=

# Google Sheets — JSON de la cuenta de servicio en una sola línea (string), para Railway/Render
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheets — ID del spreadsheet (hojas leads y conversaciones)
GOOGLE_SHEET_ID=

# Calendly — URL pública del evento (el bot la incluye al cerrar)
CALENDLY_URL=

# Modelos OpenAI (IDs según documentación de la API)
LLM_MODEL=gpt-4o
LLM_EXTRACTION_MODEL=gpt-4o-mini

# --- Opcionales (valores por defecto si no se definen) ---

# Cada cuántos mensajes del usuario se ejecuta la extracción (default: 2)
EXTRACTION_FREQUENCY=2

# Máximo de turnos (user+assistant) enviados al LLM; 0 = historial completo (default: 0)
CONVERSATION_HISTORY_MAX_MESSAGES=0

# Nivel de logging (default: INFO)
LOG_LEVEL=INFO

# Puerto del servidor — Railway/Render inyectan PORT; en local suele ser 8000
PORT=8000

# --- Telegram: typing + acumulación de mensajes (webhook) ---
# Indicador "escribiendo…" durante LLM y delay post-respuesta (true/false)
TELEGRAM_TYPING_ENABLED=false
# Renovar sendChatAction(typing) cada N segundos mientras procesa (mínimo 1)
TYPING_RENEW_INTERVAL_SECONDS=4
# Segundos de silencio antes de llamar al LLM; 0 = sin acumular (un mensaje = un turno)
MESSAGE_DEBOUNCE_SECONDS=0
# Separador al fusionar textos (en .env puedes usar \n\n para dos saltos)
MESSAGE_DEBOUNCE_JOIN=\n\n
# Milisegundos de espera tras la respuesta del LLM antes de enviar a Telegram (sustituye al delay fijo legacy)
POST_LLM_DELAY_MS=1000

# Piloto: buscar en logs "[debounce]" y "[typing]". Matriz manual sugerida en tests/test_webhook.py (docstring).
